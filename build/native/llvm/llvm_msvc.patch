+filegroup(
+    name = "libs",
+    srcs = glob(["**/*.lib"], allow_empty = True),
+)
+"""
+
+_MSVC_ALIASES_BUILD_FILE_CONTENT = """\
+package(default_visibility = ["//visibility:public"])
+
+alias(
+    name = "all_files",
+    actual = "@{target_repo}//:all_files",
+)
+
+alias(
+    name = "windows_sdk",
+    actual = "@{target_repo}//:windows_sdk",
+)
+
+alias(
+    name = "sysroot_directory",
+    actual = "@{target_repo}//:sysroot_directory",
+)
+
+alias(
+    name = "headers_include",
+    actual = "@{target_repo}//:headers_include",
+)
+
+alias(
+    name = "msvc_include",
+    actual = "@{target_repo}//:msvc_include",
+)
+
+alias(
+    name = "winsdk_ucrt_include",
+    actual = "@{target_repo}//:winsdk_ucrt_include",
+)
+
+alias(
+    name = "winsdk_shared_include",
+    actual = "@{target_repo}//:winsdk_shared_include",
+)
+
+alias(
+    name = "winsdk_um_include",
+    actual = "@{target_repo}//:winsdk_um_include",
+)
+
+alias(
+    name = "winsdk_winrt_include",
+    actual = "@{target_repo}//:winsdk_winrt_include",
+)
+
+alias(
+    name = "msvc_lib",
+    actual = "@{target_repo}//:msvc_lib",
+)
+
+alias(
+    name = "winsdk_ucrt_lib",
+    actual = "@{target_repo}//:winsdk_ucrt_lib",
+)
+
+alias(
+    name = "winsdk_um_lib",
+    actual = "@{target_repo}//:winsdk_um_lib",
+)
+
+alias(
+    name = "libs",
+    actual = "@{target_repo}//:libs",
+)
+"""
+
+def _host_tokens(repository_ctx):
+    os_name = repository_ctx.os.name.lower()
+    arch = repository_ctx.os.arch.lower()
+
+    if os_name.startswith("mac os"):
+        os_token = "darwin"
+    elif os_name.startswith("linux"):
+        os_token = "linux"
+    elif os_name.startswith("windows"):
+        os_token = "windows"
+    else:
+        os_token = ""
+
+    if arch in ["arm64", "aarch64"]:
+        arch_tokens = ["arm64", "aarch64"]
+    elif arch in ["x86_64", "amd64"]:
+        arch_tokens = ["x86_64", "amd64"]
+    else:
+        arch_tokens = []
+
+    return os_token, arch_tokens
+
+def _default_winsysroot_urls(repository_ctx):
+    os_token, arch_tokens = _host_tokens(repository_ctx)
+    if not os_token or not arch_tokens:
+        return []
+
+    tag = repository_ctx.attr.winsysroot_version
+    repo_base = "https://github.com/ArchangelX360/winsysroot/releases/download/{}".format(tag)
+    urls = []
+    for arch_token in arch_tokens:
+        # Try common artifact naming patterns used in GitHub release binaries.
+        urls.extend([
+            "{}/winsysroot-{}-{}".format(repo_base, os_token, arch_token),
+            "{}/winsysroot_{}_{}".format(repo_base, os_token, arch_token),
+            "{}/winsysroot-{}-{}-{}".format(repo_base, tag, os_token, arch_token),
+            "{}/winsysroot_{}_{}_{}".format(repo_base, tag, os_token, arch_token),
+            "{}/winsysroot-{}-{}.exe".format(repo_base, os_token, arch_token),
+            "{}/winsysroot_{}_{}.exe".format(repo_base, os_token, arch_token),
+            "{}/winsysroot-{}-{}-{}.exe".format(repo_base, tag, os_token, arch_token),
+            "{}/winsysroot_{}_{}_{}.exe".format(repo_base, tag, os_token, arch_token),
+        ])
+    return urls
+
+def _winsysroot_repository_impl(repository_ctx):
+    winsysroot_path = repository_ctx.which("winsysroot")
+
+    default_urls = []
+    if not repository_ctx.attr.winsysroot_urls:
+        default_urls = _default_winsysroot_urls(repository_ctx)
+
+    winsysroot_urls = repository_ctx.attr.winsysroot_urls if repository_ctx.attr.winsysroot_urls else default_urls
+    if winsysroot_urls:
+        os_token, _ = _host_tokens(repository_ctx)
+        binary_name = "winsysroot.exe" if os_token == "windows" else "winsysroot"
+        winsysroot_path = repository_ctx.path(binary_name)
+        repository_ctx.download(
+            url = winsysroot_urls,
+            output = winsysroot_path,
+            executable = True,
+            sha256 = repository_ctx.attr.winsysroot_sha256,
+            integrity = repository_ctx.attr.winsysroot_integrity,
+        )
+
+    if not winsysroot_path:
+        fail("winsysroot is required. Provide msvc.winsysroot(urls = [...]) or install a `winsysroot` binary in PATH.")
+
+    cmd = [
+        str(winsysroot_path),
+        "-win-sdk-version",
+        repository_ctx.attr.windows_sdk_version,
+        "-architectures",
+        repository_ctx.attr.architectures,
+        "-out-dir",
+        "sysroot",
+    ] + repository_ctx.attr.winsysroot_extra_args
+    result = repository_ctx.execute(cmd)
+    if result.return_code != 0:
+        fail("winsysroot failed with exit code {}.\nstdout:\n{}\nstderr:\n{}".format(result.return_code, result.stdout, result.stderr))
+
+    msvc_version_dirs = repository_ctx.path("sysroot/VC/Tools/MSVC").readdir()
+    if len(msvc_version_dirs) != 1:
+        fail("Expected exactly one MSVC version under sysroot/VC/Tools/MSVC, got {}".format([d.basename for d in msvc_version_dirs]))
+    msvc_version = msvc_version_dirs[0].basename
+
+    windows_sdk_include_root = "sysroot/Windows Kits/10/Include/{}".format(repository_ctx.attr.windows_sdk_version + ".0")
+    if not repository_ctx.path(windows_sdk_include_root).exists:
+        windows_sdk_include_root = "sysroot/Windows Kits/10/Include/{}".format(repository_ctx.attr.windows_sdk_version)
+    windows_sdk_lib_root = "sysroot/Windows Kits/10/Lib/{}".format(repository_ctx.attr.windows_sdk_version + ".0")
+    if not repository_ctx.path(windows_sdk_lib_root).exists:
+        windows_sdk_lib_root = "sysroot/Windows Kits/10/Lib/{}".format(repository_ctx.attr.windows_sdk_version)
+
+    repository_ctx.symlink("sysroot/VC/Tools/MSVC/{}/include".format(msvc_version), "msvc_include")
+    repository_ctx.symlink("sysroot/VC/Tools/MSVC/{}/lib/arm64".format(msvc_version), "msvc_lib_arm64")
+    repository_ctx.symlink("sysroot/VC/Tools/MSVC/{}/lib/x64".format(msvc_version), "msvc_lib_x64")
+    repository_ctx.symlink("{}/ucrt".format(windows_sdk_include_root), "winsdk_ucrt_include")
+    repository_ctx.symlink("{}/shared".format(windows_sdk_include_root), "winsdk_shared_include")
+    repository_ctx.symlink("{}/um".format(windows_sdk_include_root), "winsdk_um_include")
+    repository_ctx.symlink("{}/winrt".format(windows_sdk_include_root), "winsdk_winrt_include")
+    repository_ctx.symlink("{}/ucrt/arm64".format(windows_sdk_lib_root), "winsdk_ucrt_lib_arm64")
+    repository_ctx.symlink("{}/ucrt/x64".format(windows_sdk_lib_root), "winsdk_ucrt_lib_x64")
+    repository_ctx.symlink("{}/um/arm64".format(windows_sdk_lib_root), "winsdk_um_lib_arm64")
+    repository_ctx.symlink("{}/um/x64".format(windows_sdk_lib_root), "winsdk_um_lib_x64")
+
+    repository_ctx.file("BUILD.bazel", _MSVC_BUILD_FILE_CONTENT)
+
+_winsysroot_repository = repository_rule(
+    implementation = _winsysroot_repository_impl,
+    attrs = {
+        "winsysroot_urls": attr.string_list(),
+        "winsysroot_sha256": attr.string(),
+        "winsysroot_integrity": attr.string(),
+        "winsysroot_version": attr.string(default = "0.0.2"),
+        "windows_sdk_version": attr.string(default = "10.0.26100"),
+        "architectures": attr.string(default = "x64,arm64"),
+        "winsysroot_extra_args": attr.string_list(),
+    },
+)
+
+def _winsysroot_alias_repository_impl(repository_ctx):
+    repository_ctx.file(
+        "BUILD.bazel",
+        _MSVC_ALIASES_BUILD_FILE_CONTENT.format(
+            target_repo = repository_ctx.attr.target_repo,
+        ),
+    )
+
+_winsysroot_alias_repository = repository_rule(
+    implementation = _winsysroot_alias_repository_impl,
+    attrs = {
+        "target_repo": attr.string(mandatory = True),
+    },
+)
+
+def _read_winsysroot_tag(module_ctx):
+    root_tags = []
+    non_root_tags = []
+    for mod in module_ctx.modules:
+        if mod.is_root:
+            root_tags.extend(mod.tags.winsysroot)
+        else:
+            non_root_tags.extend(mod.tags.winsysroot)
+
+    if len(root_tags) > 1:
+        fail("Only one msvc.winsysroot(...) tag is supported in the root module.")
+
+    if root_tags:
+        return root_tags[0]
+    if non_root_tags:
+        return non_root_tags[0]
+    return None
+
+def _msvc_extension_impl(module_ctx):
+    """Implementation of the msvc module extension."""
+
+    winsysroot_tag = _read_winsysroot_tag(module_ctx)
+
+    _winsysroot_repository(
+        name = "windows_sdk",
+        winsysroot_urls = winsysroot_tag.urls if winsysroot_tag else [],
+        winsysroot_sha256 = winsysroot_tag.sha256 if winsysroot_tag else "",
+        winsysroot_integrity = winsysroot_tag.integrity if winsysroot_tag else "",
+        winsysroot_version = winsysroot_tag.version if winsysroot_tag else "0.0.2",
+        windows_sdk_version = winsysroot_tag.windows_sdk_version if winsysroot_tag else "10.0.26100",
+        architectures = winsysroot_tag.architectures if winsysroot_tag else "x64,arm64",
+        winsysroot_extra_args = winsysroot_tag.extra_args if winsysroot_tag else [],
+    )
+
+    _winsysroot_alias_repository(
+        name = "windows_sdk_arm64",
+        target_repo = "windows_sdk",
+    )
+    _winsysroot_alias_repository(
+        name = "windows_sdk_x64",
+        target_repo = "windows_sdk",
+    )
+
+    return module_ctx.extension_metadata(
+        root_module_direct_deps = ["windows_sdk", "windows_sdk_arm64", "windows_sdk_x64"],
+        root_module_direct_dev_deps = [],
+    )
+
+_winsysroot = tag_class(
+    attrs = {
+        "urls": attr.string_list(
+            doc = "Optional prebuilt winsysroot binary URLs. If not set, URLs are auto-derived from `version`.",
+        ),
+        "version": attr.string(
+            default = "0.0.2",
+            doc = "winsysroot release tag used to derive default binary URLs.",
+        ),
+        "sha256": attr.string(
+            doc = "Optional SHA-256 for the downloaded winsysroot binary.",
+        ),
+        "integrity": attr.string(
+            doc = "Optional SRI integrity for the downloaded winsysroot binary.",
+        ),
+        "windows_sdk_version": attr.string(
+            default = "10.0.26100",
+            doc = "Windows SDK version passed to winsysroot.",
+        ),
+        "architectures": attr.string(
+            default = "x64,arm64",
+            doc = "Comma-separated architectures forwarded to winsysroot (-architectures).",
+        ),
+        "extra_args": attr.string_list(
+            doc = "Extra arguments forwarded to winsysroot.",
+        ),
+    },
+)
+
+msvc = module_extension(
+    implementation = _msvc_extension_impl,
+    tag_classes = {
+        "winsysroot": _winsysroot,
+    },
+    doc = "Extension for downloading and configuring MSVC via winsysroot.",
+)
