+directory(
+    name = "winsdk_ucrt_lib_arm64_files",
+    srcs = glob(["winsdk_ucrt_lib_arm64/**"], allow_empty = True),
+)
+
+subdirectory(
+    name = "winsdk_ucrt_lib_arm64",
+    parent = ":winsdk_ucrt_lib_arm64_files",
+    path = "winsdk_ucrt_lib_arm64",
+)
+
+directory(
+    name = "winsdk_ucrt_lib_x64_files",
+    srcs = glob(["winsdk_ucrt_lib_x64/**"], allow_empty = True),
+)
+
+subdirectory(
+    name = "winsdk_ucrt_lib_x64",
+    parent = ":winsdk_ucrt_lib_x64_files",
+    path = "winsdk_ucrt_lib_x64",
+)
